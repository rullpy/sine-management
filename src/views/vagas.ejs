<%- include('includes/head.ejs') %>
<%- include('includes/navbar.ejs') %>
<body>
    <div class="container">
        <div class="row">
            <div class="col-lg-2"></div>
                <div class="col-lg-8 my-3">
                    <p class="text-muted text-center mb-4">Cadastrando uma vaga</p>
                </div>
        </div>
    </div>   
                <%- include('includes/errors.ejs') %>
                <%- include('includes/sucess.ejs') %>

    <main class="p-4 d-flex justify-content-center">

    <div class="w-100" style="max-width: 500px;">      

    <% if(contatoId) { %>
      <form method="POST" action="/contato/vaga-criada/<%= contatoId %>">
    <% } else { %>
      <form method="POST" action="/contato/<%= empresaId %>/vaga/edit/<%= vagas._id %>">
    <% } %>
    
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="mb-3">
        <label class="form-label">Nome da vaga</label>
        <input value="<%= vagas.nome %>" type="text" class="form-control" name="nome">
      </div>

      <div class="mb-3">
        <label class="form-label">Quantidade</label>
        <input value="<%= vagas.quantidade %>" type="text" class="form-control" name="quantidade">
      </div>

        <div class="mb-3">
        <label class="form-label">Descrição</label>
        <input value="<%= vagas.description %>" type="text" class="form-control" name="description">
      </div>

      <div class="mb-3">
        <label class="form-label">Data da entrevista</label>
        <input value="<%= vagas.entrevista %>" type="tel" class="form-control" name="entrevista">
      </div>

      <button type="submit" class="btn btn-primary w-100 mt-2">
        Salvar
      </button>

    </form>

    <% if(contatoId) { %>
        <div class="d-flex gap-2">
      <a href="/contato/list-vagas/<%= contatoId %>" class="btn btn-sm btn-outline-secondary">Voltar</a>
    </div>
    <% } else { %>
        <div class="d-flex gap-2">
      <a href="/contato/list-vagas/<%= empresaId %>" class="btn btn-sm btn-outline-secondary">Voltar</a>
    </div>
    <% } %>


  </div>

</main>

<%- include('includes/footer.ejs') %>

</body>
