<%- include('includes/head.ejs') %>

<body>
    <div class="container">
        <div class="row">
            <div class="col-lg-2"></div>
            <div class="col-lg-8 my-3">
    <% if(contato._id) { %>
      <h1 class="text-center h4 mb-2"><%= contato.nome %></h1>
      <p class="text-muted text-center mb-4">Você está editando o contato dessa empresa.</p>
    <% } else { %>
      <h1 class="text-center h4 mb-2">Contatos</h1>
      <p class="text-muted text-center mb-4">Adicione um novo contato à sua agenda</p>
    <% } %>

            </div>
        </div>
    </div>   
                <%- include('includes/errors.ejs') %>
                <%- include('includes/sucess.ejs') %>

    <main class="p-4 d-flex justify-content-center">

    <div class="w-100" style="max-width: 500px;">             
    <% if(contato._id) { %>
      <form method="POST" action="/contato/edit/<%= contato._id %>">
    <% } else { %>
      <form method="POST" action="/contato/register">
    <% } %>

      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="mb-3">
        <label class="form-label">Empresa</label>
        <input value="<%= contato.nome %>" type="text" class="form-control" name="nome">
      </div>

      <div class="mb-3">
        <label class="form-label">CNPJ</label>
        <input value="<%= contato.cnpj %>" type="text" class="cnpj form-control" name="cnpj">
      </div>

      <div class="mb-3">
        <label class="form-label">Email</label>
        <input value="<%= contato.email %>" type="email" class="form-control" name="email">
      </div>

      <div class="mb-3">
        <label class="form-label">Telefone</label>
        <input value="<%= contato.telefone %>" type="tel" class="telefone form-control" name="telefone">
      </div>

      <div class="mb-3">
        <label class="form-label">Descrição</label>
        <input value="<%= contato.description %>" type="text" class="form-control" name="description">
      </div>

      <button type="submit" class="btn btn-primary w-100 mt-2">
        Salvar
      </button>

    </form>

  </div>

</main>

<%- include('includes/footer.ejs') %>
<%- include('includes/footer.ejs') %>
