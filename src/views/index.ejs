<%- include('includes/head.ejs') %>
<%- include('includes/navbar.ejs') %>

<body class="bg-principal">

<% if (user) { %>
    <div class="flex-grow-1">

      <main class="p-4">

        <% if (contatos.length > 0) { %>

          <div class="d-flex flex-column gap-3">

            <% contatos.forEach(contato => { %>

              <div class="card border-0 shadow-sm dashboard-card">
                <div class="card-body d-flex justify-content-between align-items-center">

                  <div>
                    <h6 class="fw-semibold text-dark mb-1">
                      <%= contato.nome %>
                    </h6>
                    <h6 class="fw-semibold text-dark mb-1">
                      CNPJ: <%= contato.cnpj %>
                    </h6>

                    <div class="text-muted small mb-1">
                      <%= contato.email %> • <%= contato.telefone %>
                    </div>
                  </div>

                  <div class="d-flex gap-2">
                    <a href="/contato/list-vagas/<%= contato._id %>" class="btn btn-sm btn-outline-secondary">Ver vagas</a>
                    <a href="/contato/cria-vaga/<%= contato._id %>" class="btn btn-sm btn-outline-secondary">+ Vagas</a>
                    <a href="/contato/<%= contato._id %>" class="btn btn-sm btn-outline-secondary">Editar</a>
                    <a href="/contato/delete/<%= contato._id %>" class="btn btn-sm btn-outline-danger">Excluir</a>
                  </div>

                </div>
              </div>

            <% }) %>

          </div>

        <% } else { %>

          <div class="text-center text-muted mt-5">
            <h5>Nenhum contato ainda</h5>
            <a href="/contato" class="btn btn-primary mt-3">Criar primeiro contato</a>
          </div>

        <% } %>

      </main>
    </div>
  </div>

<% } else { %>
  <main class="container py-5 text-center">
    <h3>Bem-vindo</h3>
    <p class="text-muted">Faça login para acessar o sistema</p>
  </main>

<% } %>

<%- include('includes/footer.ejs') %>

</body>